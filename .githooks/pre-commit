#!/usr/bin/env sh
set -eu

if [ "${SKIP_VERSION_BUMP:-}" = "1" ]; then
	exit 0
fi

if git diff --cached --name-only -- package.json package-lock.json manifest.json versions.json | grep -q .; then
	exit 0
fi

node version-bump.mjs --patch
git add package.json package-lock.json manifest.json versions.json
